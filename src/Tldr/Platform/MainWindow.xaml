<ui:FluentWindow x:Class="Tldr.Platform.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:Tldr.Platform"
        mc:Ignorable="d"
        Title="TLDR" Height="640" Width="480" MinHeight="400" MinWidth="360"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="TLDR" ShowMaximize="False" />

        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="16,0,16,0">

            <!-- Drag-drop overlay -->
            <Border x:Name="DragOverlay"
                    BorderBrush="{ui:ThemeResource SystemAccentColorPrimaryBrush}"
                    BorderThickness="2" CornerRadius="8"
                    Background="Transparent"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"
                    Panel.ZIndex="10" />

            <!-- READY STATE -->
            <Grid x:Name="ReadyPanel"
                  Visibility="{Binding IsReady, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="ClipboardPaste24" FontSize="48"
                                  HorizontalAlignment="Center" Margin="0,0,0,16" />
                    <ui:TextBlock Text="{Binding StatusText}"
                                  FontTypography="BodyStrong"
                                  HorizontalAlignment="Center"
                                  TextWrapping="Wrap"
                                  TextAlignment="Center" />
                    <ui:TextBlock Text="Ctrl+V to paste, or drag a file here"
                                  Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                  FontTypography="Caption"
                                  HorizontalAlignment="Center"
                                  Margin="0,8,0,0" />
                    <ui:ProgressRing IsIndeterminate="True"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                                     Width="32" Height="32"
                                     Margin="0,16,0,0"
                                     AutomationProperties.Name="Loading model" />
                </StackPanel>
            </Grid>

            <!-- LOADED STATE -->
            <Grid x:Name="LoadedPanel"
                  Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Input preview -->
                <Grid Grid.Row="0" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:Card Grid.Column="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding InputText}"
                                       MaxHeight="60" TextTrimming="CharacterEllipsis"
                                       TextWrapping="Wrap" Margin="0,0,0,4" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <ui:Badge Appearance="Secondary">
                                    <TextBlock>
                                        <Run Text="{Binding WordCount, Mode=OneWay}" />
                                        <Run Text="words" />
                                    </TextBlock>
                                </ui:Badge>
                                <TextBlock Text="{Binding InputFileName}"
                                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </ui:Card>
                    <ui:Button Grid.Column="1"
                               Icon="{ui:SymbolIcon Dismiss24}"
                               Appearance="Transparent"
                               Click="Clear_Click"
                               VerticalAlignment="Top"
                               Margin="4,0,0,0"
                               Padding="4"
                               AutomationProperties.Name="Clear input" />
                </Grid>

                <!-- Style pills -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0"
                            HorizontalAlignment="Center"
                            KeyboardNavigation.TabNavigation="Local"
                            AutomationProperties.Name="Summary style">
                    <RadioButton Content="Bullets" GroupName="Style"
                                 IsChecked="{Binding IsStyleBullets, Mode=OneWay}"
                                 Checked="StylePill_Checked" Tag="Bullets"
                                 AutomationProperties.Name="Bullet list style"
                                 Style="{StaticResource {x:Type RadioButton}}" />
                    <RadioButton Content="List" GroupName="Style"
                                 IsChecked="{Binding IsStyleList, Mode=OneWay}"
                                 Checked="StylePill_Checked" Tag="List"
                                 AutomationProperties.Name="Numbered list style"
                                 Margin="4,0,0,0" />
                    <RadioButton Content="Table" GroupName="Style"
                                 IsChecked="{Binding IsStyleTable, Mode=OneWay}"
                                 Checked="StylePill_Checked" Tag="Table"
                                 AutomationProperties.Name="Table style"
                                 Margin="4,0,0,0" />
                    <RadioButton Content="Prose" GroupName="Style"
                                 IsChecked="{Binding IsStyleProse, Mode=OneWay}"
                                 Checked="StylePill_Checked" Tag="Prose"
                                 AutomationProperties.Name="Prose style"
                                 Margin="4,0,0,0" />
                    <RadioButton Content="Same" GroupName="Style"
                                 IsChecked="{Binding IsStyleSame, Mode=OneWay}"
                                 Checked="StylePill_Checked" Tag="Same"
                                 AutomationProperties.Name="Same as original style"
                                 Margin="4,0,0,0" />
                </StackPanel>

                <!-- Detail slider -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Brief"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" x:Name="DetailSlider"
                            Minimum="0" Maximum="2"
                            Value="{Binding Detail, Mode=OneWay, Converter={local:DetailLevelToDoubleConverter}}"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            Margin="8,0,8,0"
                            AutomationProperties.Name="Detail level"
                            ValueChanged="DetailSlider_ValueChanged" />
                    <TextBlock Grid.Column="2" Text="Detailed"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Distill button -->
                <ui:Button Grid.Row="3" Content="Distill"
                           Appearance="Primary"
                           HorizontalAlignment="Stretch"
                           Margin="0,16,0,0"
                           Click="Distill_Click"
                           IsEnabled="{Binding IsBusy, Converter={local:InvertBoolConverter}}"
                           AutomationProperties.Name="Distill summary" />

                <!-- Busy indicator -->
                <StackPanel Grid.Row="4" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <ui:ProgressRing IsIndeterminate="True"
                                     Width="32" Height="32"
                                     AutomationProperties.Name="Distilling" />
                    <ui:TextBlock Text="{Binding StatusText}"
                                  FontTypography="Caption"
                                  Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                  HorizontalAlignment="Center"
                                  Margin="0,8,0,0" />
                </StackPanel>
            </Grid>

            <!-- RESULT + READING STATE (shared WebView2) -->
            <Grid Visibility="{Binding IsWebViewVisible, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- WebView2 output (visible during both Result and Reading) -->
                <wv2:WebView2 Grid.Row="0" x:Name="OutputWebView"
                              Margin="0,8,0,0"
                              DefaultBackgroundColor="Transparent"
                              AutomationProperties.Name="Summary output" />

                <!-- Result action bar -->
                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,8"
                            Visibility="{Binding IsResult, Converter={StaticResource BoolToVis}}">
                    <ui:Button Content="Copy" Icon="{ui:SymbolIcon Copy24}"
                               Click="Copy_Click" Margin="0,0,4,0"
                               AutomationProperties.Name="Copy summary to clipboard" />
                    <ui:Button Content="Re-distill" Icon="{ui:SymbolIcon ArrowRepeatAll24}"
                               Click="Redistill_Click" Margin="4,0,4,0"
                               AutomationProperties.Name="Re-distill with different options" />
                    <ui:Button Content="Read Aloud" Icon="{ui:SymbolIcon Speaker224}"
                               Click="ReadAloud_Click" Margin="4,0,4,0"
                               AutomationProperties.Name="Read summary aloud" />
                    <ui:Badge Appearance="Info" Margin="4,0,0,0" VerticalAlignment="Center">
                        <TextBlock>
                            <Run Text="{Binding SentenceCount, Mode=OneWay}" />
                            <Run Text="sentences" />
                        </TextBlock>
                    </ui:Badge>
                </StackPanel>

                <!-- Reading playback controls -->
                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,8"
                            Visibility="{Binding IsReading, Converter={StaticResource BoolToVis}}">
                    <ui:Button Click="Pause_Click"
                               AutomationProperties.Name="Pause or resume reading">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Content" Value="Pause" />
                                <Setter Property="Icon" Value="{ui:SymbolIcon Pause24}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                        <Setter Property="Content" Value="Resume" />
                                        <Setter Property="Icon" Value="{ui:SymbolIcon Play24}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <ui:Button Content="Stop" Icon="{ui:SymbolIcon Stop24}"
                               Click="Stop_Click" Margin="8,0,0,0"
                               AutomationProperties.Name="Stop reading" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Grid Grid.Row="2" Margin="16,4,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Column="0" Text="{Binding StatusText}"
                          Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                          FontTypography="Caption"
                          TextTrimming="CharacterEllipsis"
                          VerticalAlignment="Center" />
            <ui:Button Grid.Column="1"
                       x:Name="SettingsButton"
                       Icon="{ui:SymbolIcon Settings24}"
                       Appearance="Transparent"
                       Padding="4"
                       Click="Settings_Click"
                       AutomationProperties.Name="Settings" />
            <Popup x:Name="SettingsPopup"
                   PlacementTarget="{Binding ElementName=SettingsButton}"
                   Placement="Top"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="{ui:ThemeResource ApplicationBackgroundBrush}"
                        BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16" Margin="4">
                    <StackPanel Width="180"
                                KeyboardNavigation.TabNavigation="Local">
                        <TextBlock Text="Tone" FontWeight="SemiBold" Margin="0,0,0,4"
                                   AutomationProperties.HeadingLevel="Level2" />
                        <RadioButton Content="Neutral" GroupName="Tone" Tag="Neutral"
                                     AutomationProperties.Name="Neutral tone"
                                     IsChecked="{Binding IsToneNeutral, Mode=OneWay}" Checked="TonePill_Checked" />
                        <RadioButton Content="Formal" GroupName="Tone" Tag="Formal"
                                     AutomationProperties.Name="Formal tone"
                                     IsChecked="{Binding IsToneFormal, Mode=OneWay}" Checked="TonePill_Checked" />
                        <RadioButton Content="Casual" GroupName="Tone" Tag="Casual"
                                     AutomationProperties.Name="Casual tone"
                                     IsChecked="{Binding IsToneCasual, Mode=OneWay}" Checked="TonePill_Checked" />
                        <Separator Margin="0,8" />
                        <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,0,0,4"
                                   AutomationProperties.HeadingLevel="Level2" />
                        <RadioButton Content="System" GroupName="Theme" Tag="System"
                                     AutomationProperties.Name="System theme"
                                     IsChecked="True" Checked="ThemePill_Checked" />
                        <RadioButton Content="Dark" GroupName="Theme" Tag="Dark"
                                     AutomationProperties.Name="Dark theme"
                                     Checked="ThemePill_Checked" />
                        <RadioButton Content="Light" GroupName="Theme" Tag="Light"
                                     AutomationProperties.Name="Light theme"
                                     Checked="ThemePill_Checked" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</ui:FluentWindow>
